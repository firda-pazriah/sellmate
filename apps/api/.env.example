# --- Server ---
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed origins for CORS (the web app URL(s))
CORS_ORIGINS=http://localhost:3000

# Set to true only when running behind a trusted reverse proxy (nginx, Vercel, etc.)
TRUST_PROXY=false

# --- Supabase (server-side only — never expose this key to a client) ---
# Use the SECRET key (Project Settings -> API -> "Secret keys", sb_secret_...),
# the successor to the legacy service_role key. Do NOT use the publishable
# key here — it respects Row Level Security and our tables have RLS enabled
# with no policies, so a publishable key can't read/write them at all.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=YOUR-SECRET-KEY

# --- JWT access token ---
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_ISSUER=sellmate-api
JWT_AUDIENCE=sellmate-app

# --- Refresh token ---
# Generate with: openssl rand -base64 64
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret-at-least-32-chars
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
REFRESH_COOKIE_NAME=sm_refresh_token

# --- Account lockout ---
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# --- Bootstrap ---
# Allows the very first registered account to become "owner". Set to false
# once the owner account exists, so /auth/register can be disabled or gated.
ALLOW_PUBLIC_REGISTRATION=true
